#!/bin/bash

set -e

echo "Running pre-commit checks..."

if ! command -v fvm >/dev/null 2>&1; then
    echo "FVM is not installed. Please install FVM to run pre-commit checks."
    exit 1
fi

echo "Sorting imports..."
fvm dart run import_sorter:main

if ! git diff --quiet -- lib test; then
    echo "Import sorter changed files. Please review and stage the changes, then commit again."
    exit 1
fi

echo "Checking formatting..."
fvm dart format lib/ test/ --set-exit-if-changed

echo "Running analyzer..."
fvm flutter analyze

echo "All pre-commit checks passed."
