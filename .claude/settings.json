{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./android/key.properties)",
      "Read(./android/app/*.jks)",
      "Read(./ios/**/*.p12)",
      "Read(./ios/**/*.mobileprovision)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)"
    ]
  }
}
